# ── Copy this to .env for LOCAL development ──────────────────────────

SECRET_KEY=django-insecure-replace-with-a-strong-random-key-in-production

DEBUG=True

ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com

# ── PostgreSQL (Local Development) ───────────────────────────────────
# Install PostgreSQL locally and create a database first:
#   CREATE DATABASE apartment_db;
DB_NAME=apartment_db
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_HOST=localhost
DB_PORT=5432

# ── PostgreSQL (Production - Render) ─────────────────────────────────
# Render provides this automatically when you add a PostgreSQL database.
# If set, this OVERRIDES the DB_* settings above.
# Example: postgres://user:pass@dpg-xxxxx.render.com/dbname
# DATABASE_URL=

# ── CORS — your React frontend URL(s) ────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-app.vercel.app

# ── CSRF trusted origins (for production) ────────────────────────────
CSRF_TRUSTED_ORIGINS=https://*.onrender.com,https://*.vercel.app

# ── Email (Gmail SMTP) for reminders ─────────────────────────────────
# 1. Go to https://myaccount.google.com/security
# 2. Enable "2-Step Verification"
# 3. Go to https://myaccount.google.com/apppasswords
# 4. Create an app password for "Mail" -> copy the 16-character code
EMAIL_HOST_USER=youremail@gmail.com
EMAIL_HOST_PASSWORD=your16characterapppassword
DEFAULT_FROM_EMAIL=youremail@gmail.com

# Link included in reminder emails (your Vercel frontend URL)
FRONTEND_URL=https://your-app.vercel.app
